# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# E2E / QA test artifacts (local only)
e2e/.report/
e2e/.qa-fixture.json
e2e/.ids.json
e2e/.report
supabase/.temp/

# local agent worktrees (not part of the app)
.claude/worktrees/
# scratch concatenated SQL (real migrations live in supabase/migrations/)
/apply_new_sections_2026-06-17.sql

# Internal docs + audit trackers — kept locally, excluded from the pushed/production repo
/CLAUDE.md
/AGENTS.md
/qa-release/
/docs/Audits/
/docs/release/
/dev-server-qa*.log

# Local working files / Excel temp files
*.xlsx
~$*
/build-output-session*.txt
/dev-crawl.log
/dev-server-verify.log

# tesseract.js OCR model files (downloaded at runtime, never committed)
*.traineddata
